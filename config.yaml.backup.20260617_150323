    m15_min_candles: 8
  full_mode:
    m5_min_candles: 50
    m15_min_candles: 32
    h1_min_candles: 12
trading:
  instrument: XAUUSD
  mode: medium
  min_confidence: 65
  preferred_min_confidence: 70
  high_confidence: 80
  max_signals_per_day: 999
  cooldown_minutes_same_direction: 15
  cooldown_minutes_any_signal: 20
risk:
  min_sl_points: 4.0
  ideal_sl_min_points: 5.0
  ideal_sl_max_points: 8.0
  max_sl_points: 10.0
  tp1_min_points: 4.0
